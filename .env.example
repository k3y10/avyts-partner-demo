# Leave unset to use the built-in Next.js route handlers.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
DATABASE_URL=

# Set to 1 to require live upstream/API data and disable local/mock fallbacks.
NEXT_PUBLIC_REQUIRE_LIVE_TERRAIN_DATA=0

# Optional local JSON storage path. Leave blank on Vercel; use DATABASE_URL for persistent production storage.
AVYTS_OBSERVATION_STORAGE_DIR=

# Primary admin login. Username can be a plain username or an email address.
AVYTS_ADMIN_USERNAME=admin
AVYTS_ADMIN_PASSWORD=k3y10

# Additional allowed users. Separate entries with semicolons or real newlines.
# Vercel is easiest with semicolons, for example:
# AVYTS_ALLOWED_USERS=edsearch@utahavalanchecenter.org=k3y10;k3y10@gmail.com=k3y10
# You can also use different passwords per user:
# AVYTS_ALLOWED_USERS=first@example.com=pass-one;second@example.com=pass-two
AVYTS_ALLOWED_USERS=edsearch@utahavalanchecenter.org=k3y10;k3y10@gmail.com=k3y10

# Required for login/session signing in all environments.
AVYTS_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
